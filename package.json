{
  "name": "@polarnl/polarui-react",
  "version": "0.1.3",
  "description": "PolarNL's Design system.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm -s build:css && tsc",
    "build:css": "pnpx @tailwindcss/cli -i ./src/styles.css -o ./dist/styles.css --minify",
    "prepublishOnly": "pnpm build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "design-system",
    "polarui",
    "polarnl"
  ],
  "author": "polarnl",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/polarnl/polarui-react"
  },
  "homepage": "https://ui.polarnl.org/",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/react": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "storybook": "^10.1.11",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "clsx": "^2.1.1",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwind-merge": "^3.4.0"
  },
  "dependencies": {
    "gsap": "^3.15.0"
  },
  "files": [
    "dist"
  ]
}